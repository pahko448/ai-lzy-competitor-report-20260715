View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="2" text="想先问问，现在这个低落的感觉，是突然出现的，还是已经持续了一段时间呢？" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="3" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="4" text="分享" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="4" text="It" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="5" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="6" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="没关系，有时候就是觉得好像说什么都不太对，或者干脆不想说。用“It”来指代那种感觉，我也能懂。&#128524;" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="1" text="那我们就静静待一会儿也可以。如果你不想说话，我可以陪你安静地坐一会儿，或者如果你愿意，也可以试着把那个“It”画下来、打字打出来，用什么方式都行。按你的节奏来就好。" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="2" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="3" text="分享" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="7" text="It has lasted for two weeks%and%affects my sleep" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="8" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="9" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[30,0][688,480]"><node index="0" text="持续两周，还影响到睡眠，这种状态一定让你感到既疲惫又无力吧。&#128564;" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,36][660,122]" /><node index="1" text="身体在睡着的时候其实也在悄悄处理我们白天的情绪，所以睡不好本身就会让那个低落的“It”更加沉重。能坚持两周，本身就需要很大的力量了。" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,140][660,268]" /><node index="2" text="想知道在这两周里，是入睡比较困难，还是容易半夜醒来呢？" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,284][660,372]" /><node index="3" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,408][96,456]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,408][96,444]" /></node><node index="4" text="分享" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[568,408][660,444]" /></node><node index="10" text="I have trouble falling asleep" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[274,508][690,602]" /><node index="11" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[110,646][212,678]" /><node index="12" text="" resource-id="" class="androi
ounds="[0,62][86,148]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,62][86,148]" /></node><node index="1" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[634,70][720,138]"><node index="0" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[552,70][622,138]"><node index="0" text="" resource-id="" class="android.widget.Image" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[552,70][622,138]" /></node><node index="1" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[646,82][690,126]" /></node></node></node><node index="1" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="true" long-clickable="false" password="false" selected="false" bounds="[0,146][720,1506]"><node index="0" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="1" text="怎样有效调节低落的情绪呢" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="2" text=" " resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="3" text=" " resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="4" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="5" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="能感受到你此刻心里有点沉沉的，那种提不起劲的感觉确实不好受。&#128524;" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="1" text="这种低落的情绪，有时像一片乌云，不管它是什么原因来的，它本身就在提醒你：你需要一些温柔的照顾了。" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="2" text="想先问问，现在这个低落的感觉，是突然出现的，还是已经持续了一段时间呢？" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="3" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="4" text="分享" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="6" text="It" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="7" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="8" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="没关系，有时候就是觉得好像说什么都不太对，或者干脆不想说。用“It”来指代那种感觉，我也能懂。&#128524;" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="1" text="那我们就静静待一会儿也可以。如果你不想说话，我可以陪你安静地坐一会儿，或者如果你愿意，也可以试着把那个“It”画下来、打字打出来，用什么方式都行。按你的节奏来就好。" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="2" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="3" text="分享" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="9" text="It has lasted for two weeks%and%affects my sleep" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="10" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="11" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="持续两周，还影响到睡眠，这种状态一定让你感到既疲惫又无力吧。&#128564;" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="1" text="身体在睡着的时候其实也在悄悄处理我们白天的情绪，所以睡不好本身就会让那个低落的“It”更加沉重。能坚持两周，本身就需要很大的力量了。" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="2" text="想知道在这两周里，是入睡比较困难，还是容易半夜醒来呢？" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="3" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="4" text="分享" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /></node><node index="12" text="I have trouble falling asleep" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="13" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="14" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[30,0][688,264]"><node index="0" text="入睡困难确实很折磨人，尤其是身体已经很疲惫了，但大脑就是不肯停下来。&#128532;" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][0,0]" /><node index="1" text="这种“躺下却清醒”的状态，往往和白天积压的情绪有关——那些没来得及处理的感受，到了晚上就会悄悄跑出来。你提到持续两周，这段时间里，晚上躺下时脑海里会浮现什么画面或想法吗？" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,0][660,154]" /><node index="2" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,192][96,238]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,192][96,228]" /></node><node index="3" text="分享" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[568,192][660,228]" /></node><node index="15" text="My mind keeps racing about work" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[192,290][690,384]" /><node index="16" text="鲸鱼Alice" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[110,430][212,462]" /><node index="17" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[30,488][688,1104]"><node index="0" text="工作上的思绪在晚上像脱缰的野马一样停不下来，那种感觉我懂——明明身体很累，但大脑还在反复回放白天的场景，想停也停不下来。&#128532;" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,532][660,662]" /><node index="1" text="这种状态其实很常见，我们白天没有时间和空间去处理工作上的压力，到了晚上安静下来，那些被压抑的念头就全都涌上来了。这不代表你“想太多”，而是大脑在尝试解决未完成的事情。" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,678][660,850]" /><node index="2" text="感觉你现在很疲惫，我这里有个小工具，我们一起来试一下好吗？它叫“思维刹车”，专门帮我们给那些反复打转的念头按个暂停键。" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,866][660,996]" /><node index="3" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,1032][96,1080]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[58,1032][96,1068]" /></node><node index="4" text="" resource-id="" class="android.view.View" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[142,1032][178,1080]"><node index="0" text="" resource-id="" class="android.widget.TextView" package="com.xinli.yixinli" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[142,10